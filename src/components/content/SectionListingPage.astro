---
import HomeLayout from "../../layouts/HomeLayout.astro";
import Signature from "../home/signature.astro";
import FooterMeta from "../common/FooterMeta.astro";
import "../../style/pages/content-page.css";

interface SectionCategoryEntry {
  archiveSlug: string;
  count: number;
  href: string;
  label: string;
}

interface Props {
  categories: SectionCategoryEntry[];
  pageLabel: string;
  viewAllHref: string;
  viewAllLabel: string;
}

const { categories, pageLabel, viewAllHref, viewAllLabel } = Astro.props as Props;

const toAnchorId = (value: string) => value.toLowerCase().trim().replace(/\s+/g, "-");
---

<HomeLayout mainCol2Fr="4fr" mainCol3Fr="1.5fr">
  <Signature slot="signature" />

  <section slot="profile" class="content-page content-page--listing" aria-label={`${pageLabel} listing content`}>
    <div class="content-page-body">
      <header class="listing-header">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
          <h1 class="listing-header-title" style="margin:0;">{pageLabel}</h1>
          <a href={viewAllHref}>{viewAllLabel}</a>
        </div>
      </header>

      {
        categories.length > 0 ? (
          <div class="listing-groups">
            <ol class="content-toc-list" aria-label={`${pageLabel} categories`}>
              {categories.map((category) => (
                <li id={toAnchorId(category.label)} class="content-toc-item content-toc-item--depth-2">
                  <a class="content-toc-link content-toc-link--depth-2" href={category.href}>
                    {category.label} ({category.count})
                  </a>
                </li>
              ))}
            </ol>
          </div>
        ) : (
          <p class="content-toc-empty">No content yet.</p>
        )
      }
    </div>
  </section>

  <aside slot="latest" class="content-toc" aria-label={`${pageLabel} categories`}>
    {
      categories.length > 0 ? (
        <ol class="content-toc-list">
          {categories.map((category) => (
            <li class="content-toc-item content-toc-item--depth-2">
              <a class="content-toc-link content-toc-link--depth-2" href={category.href}>
                {category.label}
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="content-toc-empty">No categories yet.</p>
      )
    }
  </aside>

  <FooterMeta slot="footer-info" />
</HomeLayout>
