---
interface TocItem {
  href: string;
  label: string;
  depth?: 1 | 2 | 3;
}

interface Props {
  items: TocItem[];
  title?: string;
  emptyText?: string;
}

const { items, title, emptyText = "No headings yet." } = Astro.props as Props;
---

{
  items.length > 0 ? (
    <>
      {title && <p class="content-toc-title">{title}</p>}
      <ol class="content-toc-list">
        {items.map((item) => (
          <li
            class:list={[
              "content-toc-item",
              `content-toc-item--depth-${item.depth ?? 2}`,
            ]}
          >
            <a class={`content-toc-link content-toc-link--depth-${item.depth ?? 2}`} href={item.href}>
              {item.label}
            </a>
          </li>
        ))}
      </ol>
    </>
  ) : (
    <p class="content-toc-empty">{emptyText}</p>
  )
}
