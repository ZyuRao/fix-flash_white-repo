---
import HomeLayout from "../layouts/HomeLayout.astro";
import CodeTime from "../components/home/CodeTime.astro";
import GitHeatmap from "../components/home/githeatmap.astro";
import Signature from "../components/home/signature.astro";
import FooterMeta from "../components/common/FooterMeta.astro";
import Icon from "../components/ui/Icon.astro";
import BilibiliIcon from "../components/ui/icons/BilibiliIcon.astro";
import NetEaseMusicIcon from "../components/ui/icons/NetEaseMusicIcon.astro";
import { Github, Mail } from "lucide-static";
import { site } from "../config/site";
import { getGitTimestamps } from "../utils/git-timestamps";
import "../style/components/home/profile.css";
import "../style/components/home/latest-articles.css";

const { profile, owner } = site;
const githubUsername = (profile.githubUsername || site.contact.githubUsername).trim();
const bilibiliId = profile.bilibiliId.trim();
const cloudMusicId = profile.cloudMusicId.trim();
const emailAddress = (profile.email || site.contact.email).trim();
const latestSourceModules = {
  ...import.meta.glob("../content/blog/*.{md,mdx}", { eager: true }),
  ...import.meta.glob("../content/note/*.{md,mdx}", { eager: true }),
};

interface BlogModule {
  frontmatter?: {
    title?: string;
  };
}

interface LatestArticleItem {
  title: string;
  href: string;
  pubDateIso: string;
  createdAtIso: string;
  updatedAtIso: string;
  displayDate: string;
  year: string;
  timestamp: number;
}

interface LatestTimelineGroup {
  year: string;
  articles: LatestArticleItem[];
}

const latestArticles = Object.entries(latestSourceModules)
  .map(([path, mod]) => {
    const frontmatter = (mod as BlogModule).frontmatter;
    const title = frontmatter?.title?.trim();
    const slug = path.split("/").pop()?.replace(/\.(md|mdx)$/i, "");
    const section = path.includes("/note/") ? "note" : "blog";
    const { createdAt, updatedAt } = getGitTimestamps(new URL(path, import.meta.url));
    const pubDate = createdAt ?? updatedAt;

    if (!title || !slug || !pubDate || Number.isNaN(pubDate.getTime())) return null;

    return {
      title,
      href: `/${section}/${slug}/`,
      pubDateIso: pubDate.toISOString(),
      createdAtIso: createdAt?.toISOString() ?? pubDate.toISOString(),
      updatedAtIso: updatedAt?.toISOString() ?? pubDate.toISOString(),
      displayDate: `${pubDate.toISOString().slice(5, 7)}.${pubDate.toISOString().slice(8, 10)}`,
      year: pubDate.toISOString().slice(0, 4),
      timestamp: pubDate.getTime(),
    } as LatestArticleItem;
  })
  .filter((item): item is LatestArticleItem => item !== null)
  .sort((a, b) => b.timestamp - a.timestamp);

const latestAnimationOrderMap = new Map(latestArticles.map((article, index) => [article.href, index]));

const latestTimelineGroups = latestArticles.reduce<LatestTimelineGroup[]>((groups, article) => {
  const currentGroup = groups[groups.length - 1];

  if (currentGroup?.year === article.year) {
    currentGroup.articles.push(article);
    return groups;
  }

  groups.push({ year: article.year, articles: [article] });
  return groups;
}, []);

const profileLinks = [
  {
    key: "github",
    label: "GitHub",
    href: githubUsername ? `https://github.com/${encodeURIComponent(githubUsername)}` : "",
    icon: Github,
    external: true,
  },
  {
    key: "bilibili",
    label: "Bilibili",
    href: bilibiliId ? `https://space.bilibili.com/${encodeURIComponent(bilibiliId)}` : "",
    icon: "",
    external: true,
  },
  {
    key: "cloud-music",
    label: "NetEase Cloud Music",
    href: cloudMusicId
      ? `https://music.163.com/#/user/home?id=${encodeURIComponent(cloudMusicId)}`
      : "",
    icon: "",
    external: true,
  },
  {
    key: "email",
    label: "Email",
    href: emailAddress ? `mailto:${emailAddress}` : "",
    icon: Mail,
    external: false,
  },
]
  .filter((item) => item.href)
  .slice(0, 4);
---

<HomeLayout>
  <Signature slot="signature" />
  <section slot="profile" class="profile-card" aria-label="Profile section">
    <img
      class="profile-avatar"
      src={profile.avatarSrc}
      alt={owner.name}
      loading="lazy"
      decoding="async"
    />
    <h2 class="profile-name">{owner.name}</h2>
    {
      profileLinks.length > 0 && (
        <nav class="profile-links" aria-label="Profile quick links">
          {
            profileLinks.map((item) => (
              <a
                class="profile-link"
                href={item.href}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noreferrer" : undefined}
                aria-label={item.label}
              >
                {item.key === "bilibili" ? <BilibiliIcon /> : null}
                {item.key === "cloud-music" ? <NetEaseMusicIcon /> : null}
                {item.key !== "bilibili" && item.key !== "cloud-music" ? <Icon svg={item.icon} /> : null}
              </a>
            ))
          }
        </nav>
      )
    }
    <p class="profile-one-word">{profile.bio}</p>
    <p class="profile-bio">{profile.intro}</p>
    <CodeTime />
    <GitHeatmap />
  </section>
  <section
    slot="latest"
    class="latest-articles"
    aria-label="Latest articles section"
    data-latest-container
  >
    <h2 class="latest-articles-title">Latest Articles</h2>
    {
      latestTimelineGroups.length > 0 ? (
        <div class="latest-articles-groups" aria-label="Latest articles timeline" data-latest-groups>
          {
            latestTimelineGroups.map((group) => (
              <section class="latest-articles-group" aria-label={`${group.year} articles`} data-latest-group>
                <h3 class="latest-articles-year-label" data-latest-year>{group.year}</h3>
                <ol class="latest-articles-list" aria-label={`${group.year} timeline`}>
                  {
                    group.articles.map((article, index) => (
                      <li
                        class:list={[
                          "latest-articles-item",
                          index === 0 && "latest-articles-item--year-start",
                          index === group.articles.length - 1 && "latest-articles-item--year-end",
                        ]}
                        data-latest-item
                      >
                        <div
                          class="latest-articles-item-content"
                          style={`--latest-enter-order: ${latestAnimationOrderMap.get(article.href) ?? 0};`}
                        >
                          <time class="latest-articles-time" datetime={article.pubDateIso}>
                            {article.displayDate}
                          </time>
                          <a class="latest-articles-link" href={article.href}>
                            {article.title}
                          </a>
                        </div>
                      </li>
                    ))
                  }
                </ol>
              </section>
            ))
          }
        </div>
      ) : (
        <p class="latest-articles-empty">No articles published yet.</p>
      )
    }
    <script is:inline>
      (() => {
        const latestSection = document.querySelector("[data-latest-container]");
        if (!(latestSection instanceof HTMLElement)) return;

        const groupsRoot = latestSection.querySelector("[data-latest-groups]");
        if (!(groupsRoot instanceof HTMLElement)) return;

        const updateGroupState = (group) => {
          const items = Array.from(group.querySelectorAll("[data-latest-item]"));
          items.forEach((item) => {
            item.classList.remove("latest-articles-item--year-start", "latest-articles-item--year-end");
          });

          const visibleItems = items.filter((item) => !item.hidden);
          group.hidden = visibleItems.length === 0;

          if (visibleItems.length > 0) {
            visibleItems[0].classList.add("latest-articles-item--year-start");
            visibleItems[visibleItems.length - 1].classList.add("latest-articles-item--year-end");
          }
        };

        const syncLatestArticles = () => {
          const sectionRect = latestSection.getBoundingClientRect();
          const sectionStyle = window.getComputedStyle(latestSection);
          const availableBottom =
            sectionRect.top + latestSection.clientHeight - parseFloat(sectionStyle.paddingBottom || "0");
          const groups = Array.from(groupsRoot.querySelectorAll("[data-latest-group]"));
          let reachedLimit = false;

          groups.forEach((group) => {
            group.hidden = false;
            const items = Array.from(group.querySelectorAll("[data-latest-item]"));

            items.forEach((item) => {
              item.hidden = false;
            });
          });

          groups.forEach((group) => {
            const items = Array.from(group.querySelectorAll("[data-latest-item]"));

            items.forEach((item) => {
              if (reachedLimit) {
                item.hidden = true;
                return;
              }

              const itemBottom = item.getBoundingClientRect().bottom;
              if (itemBottom > availableBottom) {
                item.hidden = true;
                reachedLimit = true;
              }
            });

            updateGroupState(group);
          });
        };

        let frameId = 0;
        const queueSync = () => {
          cancelAnimationFrame(frameId);
          frameId = requestAnimationFrame(syncLatestArticles);
        };

        latestSection.setAttribute("data-latest-enhanced", "true");
        queueSync();
        requestAnimationFrame(() => {
          latestSection.classList.add("latest-articles--entered");
        });

        if ("ResizeObserver" in window) {
          const observer = new ResizeObserver(() => {
            queueSync();
          });
          observer.observe(latestSection);
        }

        window.addEventListener("load", queueSync, { once: true });
      })();
    </script>
  </section>
  <FooterMeta slot="footer-info" />
</HomeLayout>



